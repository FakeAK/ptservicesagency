---
import type {Lang} from "../i18n";
import {getTranslations} from "../i18n";

import {cn} from "../lib/utils";

interface Props {
  lang: Lang;
}

const {lang} = Astro.props;
const t = getTranslations(lang);

const altLang: Lang = lang === "th" ? "en" : "th";
const altHref = lang === "th" ? "/en" : "/";

import thailandFlag from "../assets/flags/th.svg";
import ukFlag from "../assets/flags/en.svg";

export const buildFlag = (locale: Lang) => {
  const flag = locale === "th" ? thailandFlag : ukFlag;
  return `<img src="${flag.src}" alt="" class="h-auto w-full object-cover rounded-sm" />`;
};
---

<div class="hidden items-center gap-0 tablet:flex">
  <a href={lang === 'th' ? '/' : '/en'} class="px-5 py-2 text-[15px] font-semibold text-primary no-underline hover:text-nav-hover">
    {t.nav.home}
  </a>

  <!-- Services Dropdown -->
  <div class="group relative">
    <button class="px-5 py-2 text-[15px] font-semibold text-primary hover:text-nav-hover">
      {t.nav.services}
    </button>
    <div
      class="pointer-events-none absolute top-full left-0 z-50 min-w-[280px] overflow-hidden rounded-xl border-2 border-primary bg-white opacity-0 shadow-lg transition-opacity group-hover:pointer-events-auto group-hover:opacity-100"
    >
      {
        t.nav.servicesDropdown.map(item => (
          <a href="#" class="block px-5 py-2.5 text-sm text-primary no-underline hover:bg-gray-50">
            {item.label}
          </a>
        ))
      }
    </div>
  </div>

  <!-- Visa Dropdown -->
  <div class="group relative">
    <a href="#" class="px-5 py-2 text-[15px] font-semibold text-primary no-underline hover:text-nav-hover">
      {t.nav.visa}
    </a>
    <div
      class="pointer-events-none absolute top-full left-0 z-50 min-w-[220px] overflow-hidden rounded-xl border-2 border-primary bg-white opacity-0 shadow-lg transition-opacity group-hover:pointer-events-auto group-hover:opacity-100"
    >
      {
        t.nav.visaDropdown.map(item => (
          <a href="#" class="block px-5 py-2.5 text-sm text-primary no-underline hover:bg-gray-50">
            {item.label}
          </a>
        ))
      }
    </div>
  </div>

  <a href="#" class="px-5 py-2 text-[15px] font-semibold text-primary no-underline hover:text-nav-hover">
    {t.nav.contact}
  </a>
  <a href={`${lang === 'th' ? '' : '/en'}/blog/`} class="px-5 py-2 text-[15px] font-semibold text-primary no-underline hover:text-nav-hover">
    {t.nav.blog}
  </a>

  <!-- Language Switcher -->
  <div class="group relative ml-2 w-[30px]">
    <button class="flex items-center cursor-pointer">
      <Fragment set:html={buildFlag(lang)} />
    </button>
    <div
      class={cn(
        "flex flex-col",
        "absolute top-full right-0 z-50",
        "items-center",
        "w-[30px] h-auto",
        "pt-3",
        "pointer-events-none opacity-0 transition-opacity group-hover:pointer-events-auto group-hover:opacity-100"
      )}
    >
      <a href={altHref} class="block size-full h-auto w-full">
        <Fragment set:html={buildFlag(altLang)} />
      </a>
    </div>
  </div>
</div>
