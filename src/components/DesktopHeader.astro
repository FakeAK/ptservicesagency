---
import type {Lang} from "../i18n";
import {getTranslations, getLocalizedPath} from "../i18n";

import {cn} from "../lib/utils";
import NavDropdown from "./NavDropdown.astro";

interface Props {
  lang: Lang;
}

const {lang} = Astro.props;
const t = getTranslations(lang);

const altLang: Lang = lang === "th" ? "en" : "th";
const currentPath = Astro.url.pathname;
const altHref = lang === "th" ? `/en${currentPath}`.replace(/\/$/, '') : currentPath.replace(/^\/en/, "") || "/";

import thailandFlag from "../assets/flags/th.svg";
import ukFlag from "../assets/flags/en.svg";

export const buildFlag = (locale: Lang) => {
  const flag = locale === "th" ? thailandFlag : ukFlag;
  return `<img src="${flag.src}" alt="" class="h-auto w-full object-cover rounded-sm" />`;
};
---

<div class="hidden items-center gap-0 tablet:flex">
  <a href={lang === 'th' ? '/' : '/en'} class="px-5 py-2 text-[15px] font-semibold text-primary no-underline hover:text-nav-hover">
    {t.nav.home}
  </a>

  <NavDropdown label={t.nav.services} items={t.nav.servicesDropdown} lang={lang} />
  <NavDropdown label={t.nav.visa} items={t.nav.visaDropdown} lang={lang} minWidth="220px" />

  <a href={getLocalizedPath('/contact', lang)} class="px-5 py-2 text-[15px] font-semibold text-primary no-underline hover:text-nav-hover">
    {t.nav.contact}
  </a>
  <a href={getLocalizedPath('/blog', lang)} class="px-5 py-2 text-[15px] font-semibold text-primary no-underline hover:text-nav-hover">
    {t.nav.blog}
  </a>

  <!-- Language Switcher -->
  <div class="group relative ml-2 w-[30px]">
    <button class="flex items-center cursor-pointer">
      <Fragment set:html={buildFlag(lang)} />
    </button>
    <div
      class={cn(
        "flex flex-col",
        "absolute top-full right-0 z-50",
        "items-center",
        "w-[30px] h-auto",
        "pt-3",
        "pointer-events-none opacity-0 transition-opacity group-hover:pointer-events-auto group-hover:opacity-100"
      )}
    >
      <a href={altHref} class="block size-full h-auto w-full">
        <Fragment set:html={buildFlag(altLang)} />
      </a>
    </div>
  </div>
</div>
