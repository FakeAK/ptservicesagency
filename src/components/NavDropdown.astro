---
import type {Lang} from "../i18n";
import {getLocalizedPath} from "../i18n";

interface Props {
  label: string;
  items: { href: string; label: string }[];
  lang: Lang;
  href?: string;
  minWidth?: string;
}

const {label, items, lang, href, minWidth = "280px"} = Astro.props;
---

<div class="group relative">
  {href ? (
    <a href={getLocalizedPath(href, lang)} class="px-5 py-2 text-[15px] font-semibold text-primary no-underline hover:text-nav-hover">
      {label}
    </a>
  ) : (
    <button class="px-5 py-2 text-[15px] font-semibold text-primary hover:text-nav-hover">
      {label}
    </button>
  )}
  <div
    class="pointer-events-none absolute top-full left-0 z-50 overflow-hidden rounded-xl border-2 border-primary bg-white opacity-0 shadow-lg transition-opacity group-hover:pointer-events-auto group-hover:opacity-100"
    style={`min-width: ${minWidth}`}
  >
    {
      items.map(item => (
        <a href={getLocalizedPath(item.href, lang)} class="block px-5 py-2.5 text-sm text-primary font-medium no-underline hover:bg-gray-50">
          {item.label}
        </a>
      ))
    }
  </div>
</div>
