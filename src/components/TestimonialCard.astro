---
import {cn} from "../lib/utils";
import Icon from "./ui/Icon.astro";

export type TestimonialSource = "Google" | "Facebook";

interface Props {
  quote: string;
  author: string;
  rating: number;
  source: TestimonialSource;
  sourceURL: string;
  image?: string;
  date?: string;
}

const {quote, author, rating, source, sourceURL, image, date} = Astro.props;
---

<a
  href={sourceURL}
  target="_blank"
  rel="noopener noreferrer"
  class={cn("flex flex-col", "relative cursor-pointer rounded-xl", "bg-card-bg", "border border-border", "p-5", "transition-shadow duration-300 ease-in-out hover:shadow-[0_2px_8px_rgba(0,0,0,0.06)]")}
>
  <!-- Source logo (top-right) -->
  <div class="absolute right-4 top-4">
    {
      source === "Facebook" ? (
        <svg role="img" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" class="size-6 fill-blue-600">
          <path d="M9.101 23.691v-7.98H6.627v-3.667h2.474v-1.58c0-4.085 1.848-5.978 5.858-5.978.401 0 .955.042 1.468.103a8.68 8.68 0 0 1 1.141.195v3.325a8.623 8.623 0 0 0-.653-.036 26.805 26.805 0 0 0-.733-.009c-.707 0-1.259.096-1.675.309a1.686 1.686 0 0 0-.679.622c-.258.42-.374.995-.374 1.752v1.297h3.919l-.386 2.103-.287 1.564h-3.246v8.245C19.396 23.238 24 18.179 24 12.044c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.628 3.874 10.35 9.101 11.647Z" />
        </svg>
      ) : (
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="size-6">
          <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4" />
          <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853" />
          <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05" />
          <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335" />
        </svg>
      )
    }
  </div>

  <!-- Stars -->
  <div class="flex">
    {
      Array.from({length: rating}).map(() => (
        <svg class="size-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
        </svg>
      ))
    }
  </div>

  <!-- Quote -->
  <p class="flex-1 text-base text-black mt-3 leading-5.5 italic">
    &ldquo;{quote}&rdquo;
  </p>

  <!-- Author -->
  <div class="flex mt-3 items-center gap-2">
    {
      image ? (
        <img src={image} alt={author} class={cn("size-10 object-cover drag-none", source !== "Google" && "rounded-full")} loading="lazy" />
      ) : (
        <div class="flex size-9 items-center justify-center rounded-full bg-primary text-sm font-bold text-white">{author.charAt(0)}</div>
      )
    }
    <div class="flex flex-col space-y-[-2px]">
      <div class="flex items-center gap-0.5">
        <span class="text-sm font-semibold text-black">{author}</span>
        <Icon name="checkmark" class="size-5 text-green-700" />
      </div>

      {date && <span class="text-xs font-medium text-muted-foreground">{date}</span>}
    </div>

    <div class="flex items-center gap-0.5"></div>
  </div>
</a>
