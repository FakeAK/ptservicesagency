---
import type {Lang} from "../i18n";
import {getTranslations} from "../i18n";
import {Image} from "astro:assets";

import logoSrc from "../assets/logo.webp";
import lineLogo from "../assets/line-logo.svg";
import messengerLogo from "../assets/messenger-logo.svg";
import lineQrCode from "../assets/line-qr-code.webp";
import messengerQrCode from "../assets/messenger-qr-code.webp";

interface Props {
  lang: Lang;
}

const {lang} = Astro.props;
const t = getTranslations(lang);
---

<footer class="mt-24 bg-white max-[479px]:px-0">
  <div class="mx-auto max-w-[940px] border-t border-border-light py-6 max-[991px]:px-3 max-[479px]:px-2.5 max-[479px]:py-6">
    <div class="flex gap-6 max-[479px]:flex-col">
      <!-- Logo -->
      <div class="shrink-0">
        <Image src={logoSrc} alt="The logo of PT Services" class="h-20 drag-none" width={80} height={80} loading="lazy" />
      </div>

      <!-- Contact Info -->
      <div>
        <h2 class="mt-6 text-3xl text-primary">
          <strong>{t.footer.contactTitle}</strong>
        </h2>
        <ul class="mt-3 flex list-none flex-col items-start gap-0 pl-0">
          <!-- Hours -->
          <li class="py-1">
            <div class="flex items-center gap-2">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="text-primary"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 10"></polyline></svg
              >
              <p class="mb-0 ml-2 text-lg text-primary">{t.footer.hours}</p>
            </div>
          </li>
          <!-- Email -->
          <li class="py-1">
            <a href={`mailto:${t.footer.email}`} class="flex items-center gap-2 text-primary no-underline">
              <svg role="img" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 fill-current text-primary"
                ><path
                  d="M24 5.457v13.909c0 .904-.732 1.636-1.636 1.636h-3.819V11.73L12 16.64l-6.545-4.91v9.273H1.636A1.636 1.636 0 0 1 0 19.366V5.457c0-2.023 2.309-3.178 3.927-1.964L5.455 4.64 12 9.548l6.545-4.91 1.528-1.145C21.69 2.28 24 3.434 24 5.457z"
                ></path></svg
              >
              <p class="mb-0 ml-2 text-lg text-primary">{t.footer.email}</p>
            </a>
          </li>
          <!-- LINE -->
          <li class="py-1">
            <a href="https://line.me/R/oaMessage/%40ptservicesagency" class="flex items-center gap-2 text-primary no-underline">
              <svg role="img" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 fill-current text-primary"
                ><path
                  d="M19.365 9.863c.349 0 .63.285.63.631 0 .345-.281.63-.63.63H17.61v1.125h1.755c.349 0 .63.283.63.63 0 .344-.281.629-.63.629h-2.386c-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63h2.386c.346 0 .627.285.627.63 0 .349-.281.63-.63.63H17.61v1.125h1.755zm-3.855 3.016c0 .27-.174.51-.432.596-.064.021-.133.031-.199.031-.211 0-.391-.09-.51-.25l-2.443-3.317v2.94c0 .344-.279.629-.631.629-.346 0-.626-.285-.626-.629V8.108c0-.27.173-.51.43-.595.06-.023.136-.033.194-.033.195 0 .375.104.495.254l2.462 3.33V8.108c0-.345.282-.63.63-.63.345 0 .63.285.63.63v4.771zm-5.741 0c0 .344-.282.629-.631.629-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63.346 0 .628.285.628.63v4.771zm-2.466.629H4.917c-.345 0-.63-.285-.63-.629V8.108c0-.345.285-.63.63-.63.348 0 .63.285.63.63v4.141h1.756c.348 0 .629.283.629.63 0 .344-.282.629-.629.629M24 10.314C24 4.943 18.615.572 12 .572S0 4.943 0 10.314c0 4.811 4.27 8.842 10.035 9.608.391.082.923.258 1.058.59.12.301.079.766.038 1.08l-.164 1.02c-.045.301-.24 1.186 1.049.645 1.291-.539 6.916-4.078 9.436-6.975C23.176 14.393 24 12.458 24 10.314"
                ></path></svg
              >
              <p class="mb-0 ml-2 text-lg text-primary">{t.footer.lineId}</p>
            </a>
          </li>
          <!-- WhatsApp -->
          <li class="py-1">
            <a href="https://wa.me/+66909808369" class="flex items-center gap-2 text-primary no-underline">
              <svg role="img" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 fill-current text-primary"
                ><path
                  d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"
                ></path></svg
              >
              <p class="mb-0 ml-2 text-lg text-primary">{t.footer.whatsapp}</p>
            </a>
          </li>
          <!-- Facebook -->
          <li class="py-1">
            <a href="https://www.facebook.com/ptservicesagency" class="flex items-center gap-2 text-primary no-underline">
              <svg role="img" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 fill-current text-primary"
                ><path
                  d="M9.101 23.691v-7.98H6.627v-3.667h2.474v-1.58c0-4.085 1.848-5.978 5.858-5.978.401 0 .955.042 1.468.103a8.68 8.68 0 0 1 1.141.195v3.325a8.623 8.623 0 0 0-.653-.036 26.805 26.805 0 0 0-.733-.009c-.707 0-1.259.096-1.675.309a1.686 1.686 0 0 0-.679.622c-.258.42-.374.995-.374 1.752v1.297h3.919l-.386 2.103-.287 1.564h-3.246v8.245C19.396 23.238 24 18.179 24 12.044c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.628 3.874 10.35 9.101 11.647Z"
                ></path></svg
              >
              <p class="mb-0 ml-2 text-lg text-primary">{t.footer.facebookName}</p>
            </a>
          </li>
          <!-- Instagram -->
          <li class="py-1">
            <a href="https://www.instagram.com/pt_services_agency/" class="flex items-center gap-2 text-primary no-underline">
              <svg role="img" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 fill-current text-primary"
                ><path
                  d="M7.0301.084c-1.2768.0602-2.1487.264-2.911.5634-.7888.3075-1.4575.72-2.1228 1.3877-.6652.6677-1.075 1.3368-1.3802 2.127-.2954.7638-.4956 1.6365-.552 2.914-.0564 1.2775-.0689 1.6882-.0626 4.947.0062 3.2586.0206 3.6671.0825 4.9473.061 1.2765.264 2.1482.5635 2.9107.308.7889.72 1.4573 1.388 2.1228.6679.6655 1.3365 1.0743 2.1285 1.38.7632.295 1.6361.4961 2.9134.552 1.2773.056 1.6884.069 4.9462.0627 3.2578-.0062 3.668-.0207 4.9478-.0814 1.28-.0607 2.147-.2652 2.9098-.5633.7889-.3086 1.4578-.72 2.1228-1.3881.665-.6682 1.0745-1.3378 1.3795-2.1284.2957-.7632.4966-1.636.552-2.9124.056-1.2809.0692-1.6898.063-4.948-.0063-3.2583-.021-3.6668-.0817-4.9465-.0607-1.2797-.264-2.1487-.5633-2.9117-.3084-.7889-.72-1.4568-1.3876-2.1228C21.2982 1.33 20.628.9208 19.8378.6165 19.074.321 18.2017.1197 16.9244.0645 15.6471.0093 15.236-.005 11.977.0014 8.718.0076 8.31.0215 7.0301.0839m.1402 21.6932c-1.17-.0509-1.8053-.2453-2.2287-.408-.5606-.216-.96-.4771-1.3819-.895-.422-.4178-.6811-.8186-.9-1.378-.1644-.4234-.3624-1.058-.4171-2.228-.0595-1.2645-.072-1.6442-.079-4.848-.007-3.2037.0053-3.583.0607-4.848.05-1.169.2456-1.805.408-2.2282.216-.5613.4762-.96.895-1.3816.4188-.4217.8184-.6814 1.3783-.9003.423-.1651 1.0575-.3614 2.227-.4171 1.2655-.06 1.6447-.072 4.848-.079 3.2033-.007 3.5835.005 4.8495.0608 1.169.0508 1.8053.2445 2.228.408.5608.216.96.4754 1.3816.895.4217.4194.6816.8176.9005 1.3787.1653.4217.3617 1.056.4169 2.2263.0602 1.2655.0739 1.645.0796 4.848.0058 3.203-.0055 3.5834-.061 4.848-.051 1.17-.245 1.8055-.408 2.2294-.216.5604-.4763.96-.8954 1.3814-.419.4215-.8181.6811-1.3783.9-.4224.1649-1.0577.3617-2.2262.4174-1.2656.0595-1.6448.072-4.8493.079-3.2045.007-3.5825-.006-4.848-.0608M16.953 5.5864A1.44 1.44 0 1 0 18.39 4.144a1.44 1.44 0 0 0-1.437 1.4424M5.8385 12.012c.0067 3.4032 2.7706 6.1557 6.173 6.1493 3.4026-.0065 6.157-2.7701 6.1506-6.1733-.0065-3.4032-2.771-6.1565-6.174-6.1498-3.403.0067-6.156 2.771-6.1496 6.1738M8 12.0077a4 4 0 1 1 4.008 3.9921A3.9996 3.9996 0 0 1 8 12.0077"
                ></path></svg
              >
              <p class="mb-0 ml-2 text-lg text-primary">{t.footer.instagramHandle}</p>
            </a>
          </li>
        </ul>
      </div>

      <!-- QR Codes (Desktop only) -->
      <div class="flex flex-1 shrink-0 gap-3 max-[991px]:hidden">
        <!-- LINE QR -->
        <div class="flex w-full flex-col items-center rounded-md border border-primary bg-white p-2.5" style="height: 300px;">
          <div class="flex items-center gap-2">
            <img src={lineLogo.src} alt="LINE" class="size-10 drag-none" loading="lazy" />
            <p class="text-sm text-primary leading-4">{t.footer.lineQrText}</p>
          </div>
          <Image src={lineQrCode} alt="LINE QR Code" class="mt-2 size-full drag-none" width={256} height={256} loading="lazy" />
        </div>
        <!-- Messenger QR -->
        <div class="flex w-full flex-col items-center rounded-md border border-primary bg-white p-2.5" style="height: 300px;">
          <div class="flex items-center gap-2">
            <img src={messengerLogo.src} alt="Messenger" class="size-10 drag-none" loading="lazy" />
            <p class="text-sm text-primary leading-4">{t.footer.messengerQrText}</p>
          </div>
          <Image src={messengerQrCode} alt="Messenger QR Code" class="mt-2 size-full p-2 drag-none" width={256} height={256} loading="lazy" />
        </div>
      </div>

      <!-- Tap to Message (Tablet/Mobile only) -->
      <div class="hidden gap-2.5 max-[991px]:flex max-[479px]:flex-col max-[479px]:gap-1.5">
        <a href="https://lin.ee/95zA7Kl" target="_blank" rel="noopener noreferrer" class="flex flex-1 items-center gap-3 rounded-md border border-primary bg-white p-3 no-underline">
          <img src={lineLogo.src} alt="LINE" class="h-[50px] w-[50px]" loading="lazy" />
          <p class="text-sm text-primary">{t.footer.lineTapText}</p>
        </a>
        <a href="https://m.me/322623954270790" target="_blank" rel="noopener noreferrer" class="flex flex-1 items-center gap-3 rounded-md border border-primary bg-white p-3 no-underline">
          <img src={messengerLogo.src} alt="Messenger" class="h-[50px] w-[50px]" loading="lazy" />
          <p class="text-sm text-primary">{t.footer.messengerTapText}</p>
        </a>
      </div>
    </div>

    <p class="mt-6 text-center text-sm text-footer-text">{t.footer.copyright}</p>
  </div>
</footer>
