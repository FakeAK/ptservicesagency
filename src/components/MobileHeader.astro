---
import type {Lang} from "../i18n";
import {getTranslations, getLocalizedPath} from "../i18n";

interface Props {
  lang: Lang;
}

const {lang} = Astro.props;
const t = getTranslations(lang);

const currentPath = Astro.url.pathname;
const thHref = lang === "th" ? currentPath : currentPath.replace(/^\/en/, "") || "/";
const enHref = lang === "en" ? currentPath : `/en${currentPath}`.replace(/\/$/, '');

import thailandFlag from "../assets/flags/th.svg";
import ukFlag from "../assets/flags/en.svg";

export const buildFlag = (locale: Lang, className: string = "") => {
  const flag = locale === "th" ? thailandFlag : ukFlag;
  return `<img src="${flag.src}" alt="" class="${className}" />`;
};
---

<!-- Mobile Menu Panel (toggled by hamburger in Navbar) -->
<div id="mobile-menu" class="hidden border-t border-border-light bg-white px-5 py-4 tablet:hidden">
  <a href={lang === 'th' ? '/' : '/en'} class="block py-2 text-[15px] font-semibold text-primary no-underline">
    {t.nav.home}
  </a>

  <!-- Services -->
  <div>
    <button class="mobile-dropdown-toggle flex w-full items-center justify-between py-2 text-[15px] font-semibold text-primary">
      {t.nav.services}
      <span class="transition-transform">&#9662;</span>
    </button>
    <div class="mobile-dropdown-content ml-4 hidden border-l-2 border-primary pl-3">
      {
        t.nav.servicesDropdown.map(item => (
          <a href="#" class="block py-1.5 text-sm text-primary no-underline">
            {item.label}
          </a>
        ))
      }
    </div>
  </div>

  <!-- Visa -->
  <div>
    <button class="mobile-dropdown-toggle flex w-full items-center justify-between py-2 text-[15px] font-semibold text-primary">
      {t.nav.visa}
      <span class="transition-transform">&#9662;</span>
    </button>
    <div class="mobile-dropdown-content ml-4 hidden border-l-2 border-primary pl-3">
      {
        t.nav.visaDropdown.map(item => (
          <a href="#" class="block py-1.5 text-sm text-primary no-underline">
            {item.label}
          </a>
        ))
      }
    </div>
  </div>

  <a href={getLocalizedPath('/contact', lang)} class="block py-2 text-[15px] font-semibold text-primary no-underline">
    {t.nav.contact}
  </a>
  <a href={getLocalizedPath('/blog', lang)} class="block py-2 text-[15px] font-semibold text-primary no-underline">
    {t.nav.blog}
  </a>

  <!-- Language Switcher Mobile -->
  <div class="mt-2 flex gap-3 border-t border-border-light pt-3">
    <a href={thHref}>
      <Fragment set:html={buildFlag("th", "h-auto w-[30px] object-contain")} />
    </a>
    <a href={enHref}>
      <Fragment set:html={buildFlag("en", "h-auto w-[30px] object-contain")} />
    </a>
  </div>
</div>

<script>
  // Mobile menu toggle
  const btn = document.getElementById("mobile-menu-btn");
  const menu = document.getElementById("mobile-menu");
  const top = document.getElementById("hamburger-top");
  const mid = document.getElementById("hamburger-mid");
  const bot = document.getElementById("hamburger-bot");

  btn?.addEventListener("click", () => {
    const isOpen = !menu?.classList.contains("hidden");
    menu?.classList.toggle("hidden");
    if (!isOpen) {
      top?.classList.add("translate-y-2", "rotate-45");
      mid?.classList.add("opacity-0");
      bot?.classList.add("-translate-y-2", "-rotate-45");
    } else {
      top?.classList.remove("translate-y-2", "rotate-45");
      mid?.classList.remove("opacity-0");
      bot?.classList.remove("-translate-y-2", "-rotate-45");
    }
  });

  // Mobile dropdown toggles
  document.querySelectorAll(".mobile-dropdown-toggle").forEach(toggle => {
    toggle.addEventListener("click", () => {
      const content = toggle.nextElementSibling;
      const arrow = toggle.querySelector("span");
      content?.classList.toggle("hidden");
      arrow?.classList.toggle("rotate-180");
    });
  });
</script>
