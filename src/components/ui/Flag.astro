---
import flagTh from "../../assets/flags/th.svg";
import flagEn from "../../assets/flags/en.svg";
import flagUs from "../../assets/flags/us.svg";
import flagFr from "../../assets/flags/fr.svg";
import flagDe from "../../assets/flags/de.svg";
import flagEs from "../../assets/flags/es.svg";
import flagIt from "../../assets/flags/it.svg";
import flagBe from "../../assets/flags/be.svg";
import flagEu from "../../assets/flags/eu.svg";
import { cn } from "../../lib/utils";
import { Image } from "astro:assets";

const flagMap = {
  th: flagTh,
  en: flagEn,
  us: flagUs,
  fr: flagFr,
  de: flagDe,
  es: flagEs,
  it: flagIt,
  be: flagBe,
  eu: flagEu,
} as const;

export type FlagCode = keyof typeof flagMap;

interface Props {
  code: FlagCode;
  class?: string;
}

const { code, class: className = "w-5 aspect-4/3 rounded-xs object-cover" } = Astro.props;
const flag = flagMap[code];
---

{flag && <Image src={flag} alt="" class={cn("drag-none", className)} />}
