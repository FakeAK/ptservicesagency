---
import CheckmarkIcon from '../icons/CheckmarkIcon.astro';

export type IconName = "checkmark";

const iconMap = {
  checkmark: CheckmarkIcon,
} as const;

interface Props {
  name: IconName;
  class?: string;
}

const { name, class: className = "size-6" } = Astro.props;

const IconComponent = iconMap[name];
---

<IconComponent class={className} />
