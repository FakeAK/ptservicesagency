---
import type { Lang } from '../../i18n';
import { getTranslations, getLocalizedPath } from '../../i18n';
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import FAQAccordion from '../../components/FAQAccordion.astro';
import TestimonialCard from '../../components/TestimonialCard.astro';
import { getTestimonialsByAuthors } from '../../data/testimonials';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = getTranslations(lang);
const s = t.servicePages.ninetyDayReport;

const testimonials = getTestimonialsByAuthors(["Callie I.", "Evgenia Z."]);

const siteUrl = "https://www.ptservicesagency.com";
const canonicalPath = getLocalizedPath("/services/90-day-report-thailand", lang);

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": s.faq.map((item: { question: string; answer: string }) => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.answer,
    },
  })),
};

const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": lang === "en" ? `${siteUrl}/en` : siteUrl,
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": s.title,
      "item": `${siteUrl}${canonicalPath}`,
    },
  ],
};
---

<Layout title={s.meta.title} description={s.meta.description} lang={lang}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />
  </Fragment>

  <Navbar lang={lang} />

  <main class="mx-auto max-w-[940px] px-5 py-16">
    <h1 class="font-calsans text-3xl text-primary sm:text-4xl">{s.title}</h1>

    <div class="mt-6 text-body-text leading-relaxed" set:html={s.featuresText} />

    <!-- Documents Required -->
    <section class="mt-12">
      <h2 class="font-calsans text-2xl text-primary">{s.documentsHeading}</h2>
      <p class="mt-2 text-body-text leading-relaxed">{s.documentsIntro}</p>
      <ul class="mt-2 list-none space-y-2">
        {s.documents.map((doc) => <li class="text-body-text">✅ {doc}</li>)}
      </ul>
    </section>

    <!-- Pricing Table -->
    <section class="mt-12">
      <h2 class="font-calsans text-2xl text-primary">{s.priceHeading}</h2>
      <p class="mt-2 text-body-text leading-relaxed">{s.priceIntro}</p>
      <div class="mt-4 overflow-hidden rounded-lg border border-border-light">
        <table class="w-full text-left">
          <thead>
            <tr class="bg-primary text-primary-foreground">
              <th class="px-5 py-3 text-sm font-semibold">{s.priceTableHeaderProvince}</th>
              <th class="px-5 py-3 text-sm font-semibold">{s.priceTableHeaderPrice}</th>
            </tr>
          </thead>
          <tbody>
            {s.priceTable.map((row, i) => (
              <tr class={i % 2 === 0 ? "bg-white" : "bg-gray-50"}>
                <td class="px-5 py-3 text-body-text">{row.province}</td>
                <td class="px-5 py-3 font-semibold text-primary">{row.price}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <!-- Testimonials -->
    <section class="mt-12">
      <h2 class="font-calsans text-2xl text-primary">{t.testimonials.heading}</h2>
      <div class="mt-6 grid grid-cols-2 gap-4 max-[479px]:grid-cols-1">
        {testimonials.map(item => <TestimonialCard quote={item.quote} author={item.author} rating={item.rating} source={item.source} sourceURL={item.sourceURL} image={item.image} date={item.date} />)}
      </div>
    </section>

    <!-- FAQ -->
    <FAQAccordion heading={s.faqHeading} items={s.faq} />
  </main>

  <Footer lang={lang} />
</Layout>
