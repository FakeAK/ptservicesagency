---
import type { Lang } from '../../i18n';
import { getTranslations, getLocalizedPath } from '../../i18n';
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import FAQAccordion from '../../components/FAQAccordion.astro';

interface Props { lang: Lang; }

const { lang } = Astro.props;
const t = getTranslations(lang);
const s = t.servicePages.driverLicense;

const siteUrl = "https://www.ptservicesagency.com";
const canonicalPath = getLocalizedPath("/services/renew-thai-driver-license-service", lang);

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": s.faq.map((item: { question: string; answer: string }) => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": { "@type": "Answer", "text": item.answer },
  })),
};

const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": lang === "en" ? `${siteUrl}/en` : siteUrl },
    { "@type": "ListItem", "position": 2, "name": s.title, "item": `${siteUrl}${canonicalPath}` },
  ],
};
---

<Layout title={s.meta.title} description={s.meta.description} lang={lang}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />
  </Fragment>

  <Navbar lang={lang} />

  <main class="mx-auto max-w-[940px] px-5 py-16">
    <h1 class="font-calsans text-3xl text-primary sm:text-4xl">{s.title}</h1>
    <div class="mt-6 whitespace-pre-line text-body-text leading-relaxed">{s.intro}</div>

    <!-- Documents for First-Time Application -->
    <section class="mt-12">
      <h2 class="font-calsans text-2xl text-primary">{s.docsFirstTimeHeading}</h2>
      <ul class="mt-4 list-disc space-y-2 pl-6">
        {s.docsFirstTime.map((doc: string) => <li class="text-body-text">{doc}</li>)}
      </ul>
    </section>

    <!-- Documents for Renewal -->
    <section class="mt-12">
      <h2 class="font-calsans text-2xl text-primary">{s.docsRenewalHeading}</h2>
      <ul class="mt-4 list-disc space-y-2 pl-6">
        {s.docsRenewal.map((doc: string) => <li class="text-body-text">{doc}</li>)}
      </ul>
    </section>

    <!-- Pricing -->
    <section class="mt-12">
      <h2 class="font-calsans text-2xl text-primary">{s.priceHeading}</h2>
      <div class="mt-4 whitespace-pre-line text-body-text leading-relaxed">{s.priceIntro}</div>
      <ul class="mt-4 list-disc space-y-2 pl-6">
        {s.priceIncludes.map((item: string) => <li class="text-body-text">{item}</li>)}
      </ul>
      <p class="mt-4 text-sm italic text-body-text">{s.priceNote}</p>
    </section>

    <FAQAccordion heading={s.faqHeading} items={s.faq} />
  </main>

  <Footer lang={lang} />
</Layout>
