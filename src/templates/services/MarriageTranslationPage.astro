---
import type { Lang } from '../../i18n';
import { getTranslations, getLocalizedPath } from '../../i18n';
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import TestimonialCard from '../../components/TestimonialCard.astro';
import { getTestimonialsByAuthors } from '../../data/testimonials';

interface Props { lang: Lang; }

const { lang } = Astro.props;
const t = getTranslations(lang);
const s = t.servicePages.marriageTranslation;

const testimonials = getTestimonialsByAuthors(["Gérard D.", "Jan S."]);

const siteUrl = "https://www.ptservicesagency.com";
const canonicalPath = getLocalizedPath("/services/marriage-registration-translation-service", lang);

const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": lang === "en" ? `${siteUrl}/en` : siteUrl },
    { "@type": "ListItem", "position": 2, "name": s.title, "item": `${siteUrl}${canonicalPath}` },
  ],
};
---

<Layout title={s.meta.title} description={s.meta.description} lang={lang}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />
  </Fragment>

  <Navbar lang={lang} />

  <main class="mx-auto max-w-[940px] px-5 py-16">
    <h1 class="font-calsans text-3xl text-primary sm:text-4xl">{s.title}</h1>
    <div class="mt-6 text-body-text leading-relaxed" set:html={s.intro} />
    <ul class="mt-4 list-none space-y-2 pl-0">
      {s.introFeatures.map((f: string) => <li class="text-body-text" set:html={`✅ ${f}`} />)}
    </ul>

    <!-- Perfect For -->
    <section class="mt-12">
      <h2 class="font-calsans text-2xl text-primary">{s.suitableHeading}</h2>
      <ul class="mt-4 list-disc space-y-2 pl-6">
        {s.suitableItems.map((item: string) => <li class="text-body-text">{item}</li>)}
      </ul>
    </section>

    <!-- Service Process -->
    <section class="mt-12">
      <h2 class="font-calsans text-2xl text-primary">{s.processHeading}</h2>
      <ol class="mt-4 list-decimal space-y-2 pl-6">
        {s.processItems.map((item: string) => <li class="text-body-text">{item}</li>)}
      </ol>
    </section>

    <!-- Pricing -->
    <section class="mt-12">
      <h2 class="font-calsans text-2xl text-primary">{s.priceHeading}</h2>
      <div class="mt-4 text-body-text leading-relaxed" set:html={s.priceContent} />
    </section>

    <!-- Tips -->
    <section class="mt-12">
      <h2 class="font-calsans text-2xl text-primary">{s.tipsHeading}</h2>
      <div class="mt-4 whitespace-pre-line text-body-text leading-relaxed" set:html={s.tipsContent} />
    </section>

    <!-- Let Us Handle It -->
    <section class="mt-12">
      <h2 class="font-calsans text-2xl text-primary">{s.ctaHeading}</h2>
      <div class="mt-4 text-body-text leading-relaxed" set:html={s.ctaContent} />
      <ul class="mt-4 list-none space-y-2 pl-0">
        {s.ctaSteps.map((step: string) => <li class="text-body-text">✅ {step}</li>)}
      </ul>
      <p class="mt-4 text-body-text leading-relaxed">{s.ctaFooter}</p>
    </section>

    <!-- Testimonials -->
    <section class="mt-12">
      <h2 class="font-calsans text-2xl text-primary">{t.testimonials.heading}</h2>
      <div class="mt-6 grid grid-cols-2 gap-4 max-[479px]:grid-cols-1">
        {testimonials.map(item => <TestimonialCard quote={item.quote} author={item.author} rating={item.rating} source={item.source} sourceURL={item.sourceURL} image={item.image} date={item.date} />)}
      </div>
    </section>
  </main>

  <Footer lang={lang} />
</Layout>
