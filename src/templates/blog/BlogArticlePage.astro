---
import type {Lang} from "../../i18n";
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
import {blogImages, type BlogImageKey} from "../../lib/blogImages";
import {cn} from "../../lib/utils";

interface Props {
  title: string;
  date: Date;
  updatedDate?: Date;
  author?: string;
  excerpt: string;
  image: BlogImageKey;
  heroAlt: string;
  slug: string;
  lang: Lang;
  body?: string;
}

const {title, date, updatedDate, author = "PT Services Agency", excerpt, image, heroAlt, slug, lang, body} = Astro.props;

const heroImage = blogImages[image];

const formattedDate = date.toLocaleDateString(lang === "th" ? "th-TH" : "en-GB", {
  day: "2-digit",
  month: "long",
  year: "numeric"
});

// Estimated reading time (200 words per minute)
const wordCount = body ? body.trim().split(/\s+/).length : 0;
const readingTime = Math.max(1, Math.ceil(wordCount / 200));
const readingTimeLabel = lang === "th" ? `อ่าน ${readingTime} นาที` : `${readingTime} min read`;

// SEO: Build absolute image URL for og:image and JSON-LD
const siteUrl = "https://www.ptservicesagency.com";
const ogImageUrl = heroImage ? `${siteUrl}${heroImage.src}` : undefined;

// SEO: ISO dates for structured data
const publishedISO = date.toISOString();
const modifiedISO = updatedDate ? updatedDate.toISOString() : publishedISO;

// SEO: Canonical URL for this article
const articlePath = lang === "th" ? `/blog/${slug}` : `/en/blog/${slug}`;
const canonicalUrl = `${siteUrl}${articlePath}`;

// SEO: JSON-LD BlogPosting structured data
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": title,
  "description": excerpt,
  "image": ogImageUrl || `${siteUrl}/images/og-default.png`,
  "datePublished": publishedISO,
  "dateModified": modifiedISO,
  "author": {
    "@type": "Organization",
    "name": author,
    "url": siteUrl,
  },
  "publisher": {
    "@type": "Organization",
    "name": "PT Services Agency",
    "url": siteUrl,
    "logo": {
      "@type": "ImageObject",
      "url": `${siteUrl}/favicon.png`,
    },
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": canonicalUrl,
  },
  "inLanguage": lang === "th" ? "th" : "en",
};

// SEO: BreadcrumbList structured data
const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": lang === "th" ? "หน้าแรก" : "Home",
      "item": lang === "th" ? siteUrl : `${siteUrl}/en/`,
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Blog",
      "item": lang === "th" ? `${siteUrl}/blog/` : `${siteUrl}/en/blog/`,
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": title,
      "item": canonicalUrl,
    },
  ],
};
---

<Layout
  title={`${title} - PT Services`}
  description={excerpt}
  lang={lang}
  image={ogImageUrl}
  ogType="article"
  publishedDate={publishedISO}
  modifiedDate={modifiedISO}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />
  </Fragment>

  <Navbar lang={lang} />

  <article class="mx-auto mt-12 max-w-[940px] px-5 mb-12">
    {heroImage && <img src={heroImage.src} alt={heroAlt} class="mb-8 w-full rounded-4xl object-cover aspect-16/9" />}

    <div class="flex flex-col gap-2">
      <h1 class="font-bold leading-tighter text-primary text-3xl md:text-4xl">
        {title}
      </h1>

      <div class="mb-8 flex flex-col gap-1 text-sm text-primary/60">
        <div class="flex items-center gap-1.5">
          <svg xmlns="http://www.w3.org/2000/svg" class="size-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
            <line x1="16" y1="2" x2="16" y2="6"></line>
            <line x1="8" y1="2" x2="8" y2="6"></line>
            <line x1="3" y1="10" x2="21" y2="10"></line>
          </svg>
          <span>{formattedDate}</span>
        </div>
        <div class="flex items-center gap-1.5">
          <svg xmlns="http://www.w3.org/2000/svg" class="size-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="10"></circle>
            <polyline points="12 6 12 12 16 14"></polyline>
          </svg>
          <span>{readingTimeLabel}</span>
        </div>
      </div>
    </div>

    <div
      class={cn(
        "prose prose-lg max-w-none text-body-text",
        "prose-headings:text-primary prose-headings:font-bold",
        "prose-h2:mt-10 prose-h2:mb-1 prose-h2:text-2xl",
        "prose-h3:mt-8 prose-h3:mb-1 prose-h3:text-xl",
        "prose-p:mb-0 prose-p:leading-7 prose-p:text-base",
        "prose-a:text-royal-blue prose-a:underline prose-a:text-base",
        "prose-strong:text-primary",
        "prose-ul:pl-6 prose-ul:my-0",
        "prose-li:text-base prose-li:my-0",
        "prose-ol:my-4 prose-ol:pl-6",
        "prose-img:rounded-lg prose-img:my-6"
      )}
    >
      <slot />
    </div>
  </article>

  <Footer lang={lang} />
</Layout>
