---
import type {Lang} from "../../../i18n";
import {getTranslations} from "../../../i18n";
import TestimonialCard from "../../../components/TestimonialCard.astro";
import { testimonials } from "../../../data/testimonials";

interface Props {
  lang: Lang;
}

const {lang} = Astro.props;
const t = getTranslations(lang);
---

<section class="flex flex-col mx-auto max-w-[940px] gap-6">
  <h2 class="text-center text-3xl font-bold text-primary">
    {t.testimonials.heading}
  </h2>

  <div class="grid grid-cols-2 gap-4 max-[991px]:grid-cols-2 max-[479px]:grid-cols-1">
    {testimonials.map(item => <TestimonialCard quote={item.quote} author={item.author} rating={item.rating} source={item.source} sourceURL={item.sourceURL} image={item.image} date={item.date} />)}
  </div>
</section>
