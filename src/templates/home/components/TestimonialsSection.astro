---
import type {Lang} from "../../../i18n";
import {getTranslations} from "../../../i18n";
import TestimonialCard from "../../../components/TestimonialCard.astro";
import type {TestimonialSource} from "../../../components/TestimonialCard.astro";

interface Props {
  lang: Lang;
}

const {lang} = Astro.props;
const t = getTranslations(lang);

const GOOGLE_URL = "https://share.google/VZ0ndSIGOJW0aHXuE";
const FACEBOOK_URL = "https://www.facebook.com/ptservicesagency/reviews";

const testimonials: {
  quote: string;
  author: string;
  rating: number;
  source: TestimonialSource;
  sourceURL: string;
  image?: string;
}[] = [
  {
    quote: "This agency helped my girlfriend get her schengen visa for our summer holiday and service was top notch.",
    author: "Mateusz T.",
    rating: 5,
    source: "Google",
    sourceURL: GOOGLE_URL
  },
  {
    quote: "Very professional and efficient service. They handled all the paperwork for my 90-day report perfectly.",
    author: "Arthur K.",
    rating: 5,
    source: "Google",
    sourceURL: GOOGLE_URL
  },
  {
    quote:
      "Thank you for your excellent service! PT Service agency helped us to make 90 days reports on time. This is surely the easiest way to deal with it. The process was smooth and pleasant, no need to go anywhere and wait queues. We will definitely use your service next time 👍",
    author: "Evgenia Zykova",
    image: 
    rating: 5,
    source: "Google",
    sourceURL: GOOGLE_URL
  },
  {
    quote: "Great experience with PT Services. They made the immigration process so much easier for me.",
    author: "Filla L.",
    rating: 5,
    source: "Facebook",
    sourceURL: FACEBOOK_URL
  },
  {
    quote: "Very helpful team. They guided me through the entire visa process step by step.",
    author: "Verified Client",
    rating: 5,
    source: "Google",
    sourceURL: GOOGLE_URL
  },
  {
    quote: "Professional service and very responsive. They answered all my questions quickly.",
    author: "Krearam N.",
    rating: 5,
    source: "Facebook",
    sourceURL: FACEBOOK_URL
  },
  {
    quote: "I highly recommend PT Services for anyone needing visa assistance in Thailand.",
    author: "Jack R.",
    rating: 5,
    source: "Google",
    sourceURL: GOOGLE_URL
  },
  {
    quote: "Outstanding service from start to finish. Will definitely use them again for future visa needs.",
    author: "Richard R.",
    rating: 5,
    source: "Facebook",
    sourceURL: FACEBOOK_URL
  }
];
---

<section class="overflow-hidden">
  <div class="mx-auto max-w-[940px] px-5">
    <div class="flex items-center justify-center gap-3">
      <p class="text-2xl">&#11088;</p>
      <h2 class="mb-5 mt-0 text-center text-[28px] font-bold text-primary">
        {t.testimonials.heading}
      </h2>
      <p class="text-2xl">&#11088;</p>
    </div>

    <div class="grid grid-cols-2 gap-4 max-[991px]:grid-cols-2 max-[479px]:grid-cols-1">
      {testimonials.map(item => <TestimonialCard quote={item.quote} author={item.author} rating={item.rating} source={item.source} sourceURL={item.sourceURL} image={item.image} />)}
    </div>
  </div>
</section>
