---
import type { Lang } from '../../../i18n';
import { getTranslations, getLocalizedPath } from '../../../i18n';

import visaMan from '../../../assets/visa-man.jpg';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = getTranslations(lang);
---

<div class="flex gap-0 max-[991px]:flex-col max-[991px]:items-start">
  <img
    src={visaMan.src}
    alt="An image showing a man struggling to get his VISA to prepare his travel."
    class="w-auto max-w-[50%] rounded-lg object-cover max-[991px]:max-w-full"
    loading="lazy"
  />
  <div class="mt-6 ml-3 flex flex-1 flex-col max-[991px]:mt-6 max-[991px]:ml-0">
    <h2 class="mb-3 mt-0 text-[28px] font-bold capitalize text-primary">
      {t.visa.heading}
    </h2>
    <p class="mb-0 text-lg text-justify">
      {t.visa.description}
    </p>

    <!-- Guarantee Badge -->
    <div class="mt-6">
      <div class="flex items-start gap-3">
        <div class="shrink-0">
          <svg xmlns="http://www.w3.org/2000/svg" height="32" width="32" viewBox="0 0 24 24" fill="currentColor" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-lime-green">
            <path d="M3.85 8.62a4 4 0 0 1 4.78-4.77 4 4 0 0 1 6.74 0 4 4 0 0 1 4.78 4.78 4 4 0 0 1 0 6.74 4 4 0 0 1-4.77 4.78 4 4 0 0 1-6.75 0 4 4 0 0 1-4.78-4.77 4 4 0 0 1 0-6.76Z"/>
            <path d="m9 12 2 2 4-4"/>
          </svg>
        </div>
        <div>
          <p class="mb-0 text-xl font-bold text-primary">{t.visa.guaranteeTitle}</p>
          <p class="mb-0 text-sm text-primary">{t.visa.guaranteeText}</p>
        </div>
      </div>
    </div>

    <!-- See More Button -->
    <div class="mt-6">
      <a
        href={getLocalizedPath('/visa', lang)}
        class="inline-block w-full rounded-[4px] bg-primary bg-gradient-to-r from-primary from-25% to-primary-btn-gradient py-3 text-center text-white no-underline hover:opacity-90"
      >
        {t.visa.seeMore}
      </a>
    </div>
  </div>
</div>
