---
import type {Lang} from "../../../i18n";
import {getTranslations, getLocalizedPath} from "../../../i18n";
import {Button} from "../../../components/ui/Button";
import {Image} from "astro:assets";

import visaMan from "../../../assets/visa-man.webp";
import Icon from "../../../components/ui/Icon.astro";

interface Props {
  lang: Lang;
}

const {lang} = Astro.props;
const t = getTranslations(lang);
---

<div class="flex flex-col md:flex-row items-center justify-center gap-8">
  <Image src={visaMan} alt="An image showing a man struggling to get his VISA to prepare his travel." class="w-auto max-w-[50%] rounded-lg object-cover" width={500} height={500} loading="lazy" />
  <div class="flex flex-1 flex-col max-[991px]:mt-6 max-[991px]:ml-0">
    <div class="flex flex-col gap-2">
      <h2 class="text-[28px] font-bold capitalize text-primary">
        {t.visa.heading}
      </h2>
      <p class="mb-0 text-base text-justify">
        {t.visa.description}
      </p>
    </div>

    <!-- Guarantee Badge -->
    <div class="mt-6 border-2 border-primary rounded-xl p-3">
      <div class="flex items-start gap-3">
        <div class="shrink-0">
          <Icon name="checkmark" class="text-primary size-8" />
        </div>
        <div>
          <p class="text-xl font-bold text-primary">{t.visa.guaranteeTitle}</p>
          <p class="text-sm text-primary">{t.visa.guaranteeText}</p>
        </div>
      </div>
    </div>

    <!-- See More Button -->
    <div class="mt-6">
      <Button href={getLocalizedPath("/visa", lang)} variant="secondary" className="w-full">
        {t.visa.seeMore}
      </Button>
    </div>
  </div>
</div>
