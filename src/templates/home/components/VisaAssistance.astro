---
import type {Lang} from "../../../i18n";
import {getTranslations, getLocalizedPath} from "../../../i18n";
import {Button} from "../../../components/ui/Button";

import visaMan from "../../../assets/visa-man.jpg";

interface Props {
  lang: Lang;
}

const {lang} = Astro.props;
const t = getTranslations(lang);
---

<div class="flex flex-col md:flex-row items-center justify-center gap-8">
  <img src={visaMan.src} alt="An image showing a man struggling to get his VISA to prepare his travel." class="w-auto max-w-[50%] rounded-lg object-cover" loading="lazy" />
  <div class="flex flex-1 flex-col max-[991px]:mt-6 max-[991px]:ml-0">
    <div class="flex flex-col gap-2">
      <h2 class="text-[28px] font-bold capitalize text-primary">
        {t.visa.heading}
      </h2>
      <p class="mb-0 text-base text-justify">
        {t.visa.description}
      </p>
    </div>

    <!-- Guarantee Badge -->
    <div class="mt-6 border-2 border-primary rounded-xl p-3">
      <div class="flex items-start gap-3">
        <div class="shrink-0">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            height="32"
            width="32"
            viewBox="0 0 24 24"
            fill="currentColor"
            stroke="white"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="text-primary"
          >
            <path d="M3.85 8.62a4 4 0 0 1 4.78-4.77 4 4 0 0 1 6.74 0 4 4 0 0 1 4.78 4.78 4 4 0 0 1 0 6.74 4 4 0 0 1-4.77 4.78 4 4 0 0 1-6.75 0 4 4 0 0 1-4.78-4.77 4 4 0 0 1 0-6.76Z"></path>
            <path d="m9 12 2 2 4-4"></path>
          </svg>
        </div>
        <div>
          <p class="text-xl font-bold text-primary">{t.visa.guaranteeTitle}</p>
          <p class="text-sm text-primary">{t.visa.guaranteeText}</p>
        </div>
      </div>
    </div>

    <!-- See More Button -->
    <div class="mt-6">
      <Button href={getLocalizedPath("/visa", lang)} variant="secondary" className="w-full">
        {t.visa.seeMore}
      </Button>
    </div>
  </div>
</div>
