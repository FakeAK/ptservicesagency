---
import type {Lang} from "../../../../i18n";
import {getTranslations} from "../../../../i18n";
import happyCustomer from "../../../../assets/happy-customer.webp";

interface Props {
  lang: Lang;
}

const {lang} = Astro.props;
const t = getTranslations(lang);
---

<div class="flex items-start justify-center md:justify-start gap-4 mt-8">
  <div class="flex flex-col items-center md:items-start justify-center md:justify-start">
    <p class="text-lg italic text-primary text-center md:text-left">"{t.hero.testimonialQuote}"</p>
    <a href="https://www.facebook.com/ptservicesagency/reviews" class="mt-2 flex items-center gap-2 no-underline">
      <img src={happyCustomer.src} alt="Happy customer" class="size-10 rounded-full object-cover" loading="lazy" />
      <div>
        <div class="flex gap-0.5">
          {
            [1, 2, 3, 4, 5].map(() => (
              <svg class="size-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))
          }
        </div>
        <div class="flex items-center gap-1.5 pl-1">
          <span class="text-md text-primary">{t.hero.testimonialAuthor}</span>
          <svg role="img" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" class="size-4 fill-blue-600">
            <path
              d="M9.101 23.691v-7.98H6.627v-3.667h2.474v-1.58c0-4.085 1.848-5.978 5.858-5.978.401 0 .955.042 1.468.103a8.68 8.68 0 0 1 1.141.195v3.325a8.623 8.623 0 0 0-.653-.036 26.805 26.805 0 0 0-.733-.009c-.707 0-1.259.096-1.675.309a1.686 1.686 0 0 0-.679.622c-.258.42-.374.995-.374 1.752v1.297h3.919l-.386 2.103-.287 1.564h-3.246v8.245C19.396 23.238 24 18.179 24 12.044c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.628 3.874 10.35 9.101 11.647Z"
            ></path>
          </svg>
        </div>
      </div>
    </a>
  </div>
</div>
