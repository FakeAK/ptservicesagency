---
import type { Lang } from '../../../i18n';
import { getTranslations } from '../../../i18n';

import heroWoman from '../../../assets/hero-woman.png';
import happyCustomer from '../../../assets/happy-customer.webp';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = getTranslations(lang);
---

<section class="mt-16 flex justify-center bg-white">
  <div class="flex w-full max-w-[940px] items-start justify-between gap-9 px-5 py-0 max-[991px]:flex-wrap max-[991px]:justify-center max-[991px]:px-5 max-[991px]:pb-[180px] max-[479px]:pb-[110px]">
    <!-- Text Content -->
    <div class="flex-1">
      <h1
        class="bg-gradient-to-r from-primary from-33% to-primary-light bg-clip-text text-[40px] font-semibold leading-none text-royal-blue max-[991px]:text-[40px] max-[991px]:leading-[44px] max-[479px]:text-center max-[479px]:text-[30px] max-[479px]:leading-[37px]"
        style="-webkit-background-clip: text; -webkit-text-fill-color: transparent;"
      >
        {t.hero.title}
      </h1>

      <p class="mt-6 text-lg text-primary max-[479px]:text-center">
        {t.hero.description}
      </p>

      <!-- CTA Buttons -->
      <div class="mt-9 flex gap-3 max-[479px]:flex-col max-[479px]:items-center">
        <a
          href="#footer"
          class="inline-block rounded-[4px] bg-primary px-6 py-3 text-center leading-5 text-white no-underline hover:opacity-90"
        >
          {t.hero.ctaPrimary}
        </a>
        <a
          href="#services-container"
          class="inline-block rounded-[4px] border border-primary bg-transparent px-6 py-3 text-center leading-5 text-primary no-underline hover:bg-primary/5"
        >
          {t.hero.ctaSecondary}
        </a>
      </div>

      <!-- Testimonial Quote -->
      <div class="mt-8 flex items-start gap-1">
        <!-- Open quote -->
        <svg viewBox="0 0 16 19" xmlns="http://www.w3.org/2000/svg" fill="currentColor" class="mt-1 h-4 w-4 shrink-0 text-primary/40">
          <path d="m6.937 9.146a5.657 5.657 0 0 1 -.73 3.199 6.037 6.037 0 0 1 -2.195 2.166 6.984 6.984 0 0 1 -1.493.655q-.204.062-.41.113a2.795 2.795 0 0 1 -.396.081.792.792 0 0 1 -.422-1.499 1.49 1.49 0 0 1 .339-.096 5.753 5.753 0 0 0 .808-.245 4.68 4.68 0 0 0 2.415-2 3.063 3.063 0 0 1 -.353.176 3.11 3.11 0 0 1 -3.106-.43 3.152 3.152 0 0 1 .743-5.372 3.479 3.479 0 0 1 3.247.356 3.61 3.61 0 0 1 1.007 1.092 4.195 4.195 0 0 1 .51 1.424c.015.126.028.253.036.38zm8.848.076a5.649 5.649 0 0 1 -.758 3.161 6.052 6.052 0 0 1 -2.2 2.145 6.982 6.982 0 0 1 -1.5.649q-.203.06-.41.11a2.253 2.253 0 0 1 -.389.075.792.792 0 0 1 -.633-1.32.786.786 0 0 1 .248-.185 1.66 1.66 0 0 1 .354-.098 5.774 5.774 0 0 0 .806-.247 4.675 4.675 0 0 0 2.393-1.991 3.038 3.038 0 0 1 -.352.176 3.11 3.11 0 0 1 -3.115-.437 3.152 3.152 0 0 1 .794-5.383 3.48 3.48 0 0 1 3.248.404 3.625 3.625 0 0 1 .996 1.116 3.735 3.735 0 0 1 .315.717 3.33 3.33 0 0 1 .165.676q.027.215.038.432z"/>
        </svg>

        <div class="flex-1">
          <p class="text-sm italic text-primary/70">{t.hero.testimonialQuote}</p>
          <a href="https://www.facebook.com/ptservicesagency/reviews" class="mt-2 flex items-center gap-2 no-underline">
            <img src={happyCustomer.src} alt="Happy customer" class="h-8 w-8 rounded-full object-cover" loading="lazy" />
            <div>
              <!-- Stars -->
              <div class="flex gap-0.5">
                {[1, 2, 3, 4, 5].map(() => (
                  <svg class="h-4 w-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                  </svg>
                ))}
              </div>
              <div class="flex items-center gap-1.5">
                <span class="text-xs text-primary/60">{t.hero.testimonialAuthor}</span>
                <svg role="img" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 fill-current text-primary/40">
                  <path d="M9.101 23.691v-7.98H6.627v-3.667h2.474v-1.58c0-4.085 1.848-5.978 5.858-5.978.401 0 .955.042 1.468.103a8.68 8.68 0 0 1 1.141.195v3.325a8.623 8.623 0 0 0-.653-.036 26.805 26.805 0 0 0-.733-.009c-.707 0-1.259.096-1.675.309a1.686 1.686 0 0 0-.679.622c-.258.42-.374.995-.374 1.752v1.297h3.919l-.386 2.103-.287 1.564h-3.246v8.245C19.396 23.238 24 18.179 24 12.044c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.628 3.874 10.35 9.101 11.647Z"/>
                </svg>
              </div>
            </div>
          </a>
        </div>

        <!-- Close quote -->
        <svg viewBox="0 0 16 19" xmlns="http://www.w3.org/2000/svg" fill="currentColor" class="mt-1 h-4 w-4 shrink-0 rotate-180 text-primary/40">
          <path d="m6.937 9.146a5.657 5.657 0 0 1 -.73 3.199 6.037 6.037 0 0 1 -2.195 2.166 6.984 6.984 0 0 1 -1.493.655q-.204.062-.41.113a2.795 2.795 0 0 1 -.396.081.792.792 0 0 1 -.422-1.499 1.49 1.49 0 0 1 .339-.096 5.753 5.753 0 0 0 .808-.245 4.68 4.68 0 0 0 2.415-2 3.063 3.063 0 0 1 -.353.176 3.11 3.11 0 0 1 -3.106-.43 3.152 3.152 0 0 1 .743-5.372 3.479 3.479 0 0 1 3.247.356 3.61 3.61 0 0 1 1.007 1.092 4.195 4.195 0 0 1 .51 1.424c.015.126.028.253.036.38zm8.848.076a5.649 5.649 0 0 1 -.758 3.161 6.052 6.052 0 0 1 -2.2 2.145 6.982 6.982 0 0 1 -1.5.649q-.203.06-.41.11a2.253 2.253 0 0 1 -.389.075.792.792 0 0 1 -.633-1.32.786.786 0 0 1 .248-.185 1.66 1.66 0 0 1 .354-.098 5.774 5.774 0 0 0 .806-.247 4.675 4.675 0 0 0 2.393-1.991 3.038 3.038 0 0 1 -.352.176 3.11 3.11 0 0 1 -3.115-.437 3.152 3.152 0 0 1 .794-5.383 3.48 3.48 0 0 1 3.248.404 3.625 3.625 0 0 1 .996 1.116 3.735 3.735 0 0 1 .315.717 3.33 3.33 0 0 1 .165.676q.027.215.038.432z"/>
        </svg>
      </div>
    </div>

    <!-- Hero Image (hidden on mobile) -->
    <div class="w-[380px] shrink-0 max-[991px]:w-[256px] max-[479px]:hidden">
      <img
        src={heroWoman.src}
        alt="An illustration representing a VISA agent happy to help her customers."
        class="block w-full"
        loading="lazy"
      />
    </div>
  </div>
</section>
