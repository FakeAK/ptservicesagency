---
import type { Lang } from '../../../i18n';
import { getTranslations } from '../../../i18n';
import ServiceCard from '../../../components/ServiceCard.astro';
import {Image} from 'astro:assets';

import immigrationOfficer from '../../../assets/immigration-officer.webp';
import personalAssistant from '../../../assets/personal-assistant.webp';
import specificService from '../../../assets/specific-service.webp';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = getTranslations(lang);

const serviceImages = [
  immigrationOfficer,
  immigrationOfficer,
  immigrationOfficer,
  specificService,
  personalAssistant,
  specificService,
];

const serviceAlts = [
  'An immigration officer.',
  'An illustration of a driving license renewal.',
  'An illustration of TM.30 form filing.',
  'An illustration of document translation services.',
  'An illustration of a personal assistant.',
  'An illustration of a specific service.',
];
---

<div class="flex flex-col items-center">
  <h2 class="mb-5 mt-0 text-center text-[28px] font-bold text-primary">
    {t.services.heading}
  </h2>
  <div class="mt-3 grid w-full max-w-[940px] grid-cols-2 gap-4 max-[479px]:grid-cols-1">
    {t.services.items.map((item, i) => (
      <ServiceCard
        title={item.title}
        description={item.description}
        image={serviceImages[i]}
        imageAlt={serviceAlts[i]}
        link={item.link}
        linkText={item.linkText}
        lang={lang}
      />
    ))}
  </div>
</div>
