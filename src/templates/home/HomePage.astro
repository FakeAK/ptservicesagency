---
import type { Lang } from '../../i18n';
import { getTranslations } from '../../i18n';
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import HeroBanner from './components/HeroBanner/HeroBanner.astro';
import VisaAssistance from './components/VisaAssistance.astro';
import ImmigrationAssistance from './components/ImmigrationAssistance.astro';
import ServicesGrid from './components/ServicesGrid.astro';
import TestimonialsSection from './components/TestimonialsSection.astro';
import LatestBlog from './components/LatestBlog.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = getTranslations(lang);

const siteUrl = "https://www.ptservicesagency.com";

// SEO: Organization structured data
const organizationJsonLd = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "PT Services Agency",
  "url": siteUrl,
  "logo": `${siteUrl}/favicon.ico`,
  "description": lang === "en"
    ? "Service agency based in Bangkok specialized in visa assistance, travel planning, flight tickets booking, accommodations booking, and immigration procedures."
    : "บริษัทตัวแทนบริการในกรุงเทพฯ เชี่ยวชาญด้านวีซ่า การวางแผนการเดินทาง การจองตั๋วเครื่องบิน การจองที่พัก และขั้นตอนการตรวจคนเข้าเมือง",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Bangkok",
    "addressCountry": "TH",
  },
  "sameAs": [],
};

// SEO: WebSite structured data
const webSiteJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "PT Services Agency",
  "url": siteUrl,
  "inLanguage": ["th", "en"],
};
---

<Layout title={t.meta.title} description={t.meta.description} lang={lang}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(organizationJsonLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(webSiteJsonLd)} />
  </Fragment>

  <Navbar lang={lang} />

  <HeroBanner lang={lang} />

  <!-- Services Container -->
  <div id="services-container" class="mx-auto mt-24 md:mt-[200px] max-w-[940px]">
    <VisaAssistance lang={lang} />

    <div class="mt-24">
      <ImmigrationAssistance lang={lang} />
    </div>

    <div class="mt-[200px] max-[991px]:mt-24">
      <ServicesGrid lang={lang} />
    </div>
  </div>

  <!-- Testimonials -->
  <div class="mt-64 max-[991px]:mt-24">
    <TestimonialsSection lang={lang} />
  </div>

  <!-- Latest Blog -->
  <div id="home-blog-container" class="mt-64 max-[991px]:mt-24">
    <LatestBlog lang={lang} />
  </div>

  <!-- Footer -->
  <div id="footer">
    <Footer lang={lang} />
  </div>
</Layout>
