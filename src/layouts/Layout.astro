---
import '../styles/global.css';
import type { Lang } from '../i18n';

interface Props {
  title: string;
  description: string;
  lang: Lang;
}

const { title, description, lang } = Astro.props;
const currentPath = Astro.url.pathname;

// Build alternate URL
let altPath: string;
if (lang === 'th') {
  altPath = `/en${currentPath}`;
} else {
  altPath = currentPath.replace(/^\/en/, '') || '/';
}
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="twitter:title" content={title} />

    <!-- Hreflang -->
    <link rel="alternate" hreflang="x-default" href="https://www.ptservicesagency.com/" />
    <link rel="alternate" hreflang="th" href={`https://www.ptservicesagency.com${lang === 'th' ? currentPath : altPath}`} />
    <link rel="alternate" hreflang="en" href={`https://www.ptservicesagency.com${lang === 'en' ? currentPath : altPath}`} />

    <!-- Favicon -->
    <link rel="shortcut icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- Generator -->
    <meta name="generator" content={Astro.generator} />

    <!-- Google Analytics -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-Q7J8NW458W"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-Q7J8NW458W');
    </script>

    <!-- Facebook Pixel -->
    <script is:inline>
      !function(f,b,e,v,n,t,s){if(f.fbq)return;n=f.fbq=function(){n.callMethod?
      n.callMethod.apply(n,arguments):n.queue.push(arguments)};if(!f._fbq)f._fbq=n;
      n.push=n;n.loaded=!0;n.version='2.0';n.queue=[];t=b.createElement(e);t.async=!0;
      t.src=v;s=b.getElementsByTagName(e)[0];s.parentNode.insertBefore(t,s)}(window,
      document,'script','https://connect.facebook.net/en_US/fbevents.js');
      fbq('init', '436300629235229');
      fbq('track', 'PageView');
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>
