---
import '../styles/global.css';
import type { Lang } from '../i18n';

interface Props {
  title: string;
  description: string;
  lang: Lang;
  image?: string;
  ogType?: 'website' | 'article';
  publishedDate?: string;
  modifiedDate?: string;
  noIndex?: boolean;
}

const {
  title,
  description,
  lang,
  image,
  ogType = 'website',
  publishedDate,
  modifiedDate,
  noIndex = false,
} = Astro.props;

const siteUrl = 'https://www.ptservicesagency.com';
const currentPath = Astro.url.pathname;
const canonicalUrl = `${siteUrl}${currentPath}`;

// Build alternate URLs for hreflang
let altPath: string;
if (lang === 'th') {
  altPath = `/en${currentPath}`.replace(/\/$/, '');
} else {
  altPath = currentPath.replace(/^\/en/, '') || '/';
}

const thUrl = `${siteUrl}${lang === 'th' ? currentPath : altPath}`;
const enUrl = `${siteUrl}${lang === 'en' ? currentPath : altPath}`;

// OG image: use provided image or fallback to default
const ogImage = image || `${siteUrl}/images/og-default.png`;

// OG locale mapping
const ogLocale = lang === 'th' ? 'th_TH' : 'en_GB';
const ogLocaleAlt = lang === 'th' ? 'en_GB' : 'th_TH';
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={noIndex ? 'noindex, nofollow' : 'index, follow'} />

    <!-- Canonical -->
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content={ogType} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:locale:alternate" content={ogLocaleAlt} />
    <meta property="og:site_name" content="PT Services Agency" />
    {ogType === 'article' && publishedDate && (
      <meta property="article:published_time" content={publishedDate} />
    )}
    {ogType === 'article' && modifiedDate && (
      <meta property="article:modified_time" content={modifiedDate} />
    )}

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Hreflang -->
    <link rel="alternate" hreflang="x-default" href={thUrl} />
    <link rel="alternate" hreflang="th" href={thUrl} />
    <link rel="alternate" hreflang="en" href={enUrl} />

    <!-- Favicon -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- Google Fonts (non-render-blocking load) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Source+Sans+3:ital,wght@0,200..900;1,200..900&display=swap"
      onload="this.onload=null;this.rel='stylesheet'"
    />
    <noscript>
      <link href="https://fonts.googleapis.com/css2?family=Source+Sans+3:ital,wght@0,200..900;1,200..900&display=swap" rel="stylesheet" />
    </noscript>

    <!-- CalSans font preload (eliminate CSS→font chain) -->
    <link rel="preload" href="/fonts/CalSans-Regular.woff2" as="font" type="font/woff2" crossorigin />

    <!-- Generator -->
    <meta name="generator" content={Astro.generator} />

    <!-- Google Analytics -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-Q7J8NW458W"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-Q7J8NW458W');
    </script>

    <!-- Facebook Pixel -->
    <script is:inline>
      !function(f,b,e,v,n,t,s){if(f.fbq)return;n=f.fbq=function(){n.callMethod?
      n.callMethod.apply(n,arguments):n.queue.push(arguments)};if(!f._fbq)f._fbq=n;
      n.push=n;n.loaded=!0;n.version='2.0';n.queue=[];t=b.createElement(e);t.async=!0;
      t.onerror=function(){};
      t.src=v;s=b.getElementsByTagName(e)[0];s.parentNode.insertBefore(t,s)}(window,
      document,'script','https://connect.facebook.net/en_US/fbevents.js');
      if(window.fbq){fbq('init', '436300629235229');fbq('track', 'PageView');}
    </script>

    <!-- Structured data slot (filled by individual pages) -->
    <slot name="head" />
  </head>
  <body>
    <slot />
  </body>
</html>
